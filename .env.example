# Supabase — obtener en https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# URL pública de la app (invitaciones y OAuth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Solo servidor (Next.js API routes — nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Desktop (Electron) — mismas variables públicas
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Solo proceso principal Electron (invitaciones admin) — copiar también a apps/desktop/.env.local
# Nunca exponer al renderer (no usar prefijo VITE_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VITE_SITE_URL=http://localhost:3000
